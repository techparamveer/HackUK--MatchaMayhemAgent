# ── Model backend ───────────────────────────────────────────────────────────
# The agent never uses the Vercel AI Gateway. Pick how the model is served:
#   local        (default) your own OpenAI-compatible endpoint — e.g. a
#                claude-code-router or LiteLLM bridge running off your Claude
#                Code / Codex subscription, or Ollama / LM Studio
#   codex        bills your ChatGPT subscription via `codex login`
#   claude-code  bills your Claude subscription via the `claude` CLI
#   anthropic    direct Anthropic Messages API against your own endpoint
MODEL_BACKEND=local

# Your own endpoint (MODEL_BACKEND=local). The base URL of any
# OpenAI-compatible server; the key is optional if the endpoint needs one.
LOCAL_ENDPOINT_URL=http://localhost:4000/v1
# LOCAL_ENDPOINT_API_KEY=

# Optional model override for the chosen backend:
#   local:        whatever your endpoint calls the model
#   codex:        a bare OpenAI slug, e.g. gpt-5.5 (default gpt-5.6-sol)
#   claude-code:  fable | opus | sonnet | haiku or a full Claude model id
#   anthropic:    a Claude model id, e.g. claude-sonnet-4-6
# MODEL_ID=

# Context window declared to eve (own-endpoint and subscription models carry
# no gateway metadata). Defaults to 200000.
# MODEL_CONTEXT_WINDOW_TOKENS=200000

# ── Own endpoint, Anthropic flavour (MODEL_BACKEND=anthropic only) ──────────
# Leave BASE_URL unset for api.anthropic.com.
# ANTHROPIC_BASE_URL=
# ANTHROPIC_API_KEY=

# ── Zoho Mail MCP ───────────────────────────────────────────────────────────
# Generate this URL in the Zoho MCP console (https://mcp.zoho.com) for the
# HackUK Zoho Mail account. The URL itself is the credential — treat it like
# a password and never commit it.
# ZOHO_MCP_URL=
